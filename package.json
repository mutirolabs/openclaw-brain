{
  "name": "@mutirolabs/openclaw-brain",
  "version": "0.2.0",
  "description": "The official Mutiro Channel extension for OpenClaw. OpenClaw is the brain; Mutiro is the messaging surface, identity, and state.",
  "type": "module",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/mutirolabs/openclaw-brain.git"
  },
  "homepage": "https://github.com/mutirolabs/openclaw-brain#readme",
  "bugs": {
    "url": "https://github.com/mutirolabs/openclaw-brain/issues"
  },
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "gateway": "openclaw gateway run",
    "prepublishOnly": "npm run check"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mutiro",
    "openclaw",
    "channel",
    "extension",
    "agent"
  ],
  "files": [
    "index.ts",
    "src",
    "docs",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.10"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "^2026.4.15",
    "typescript": "^5.6.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "mutiro",
      "label": "Mutiro",
      "selectionLabel": "Mutiro",
      "docsPath": "/channels/mutiro",
      "docsLabel": "mutiro",
      "blurb": "Official Mutiro Channel for OpenClaw. Point at a Mutiro agent directory to enable.",
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@mutirolabs/openclaw-brain",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    }
  }
}
